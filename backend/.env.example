# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- Google Cloud / Vertex AI ---
GCP_PROJECT_ID=portfolio-agent-499115
GCP_LOCATION=us-central1
# Generation + embedding models (Vertex AI publisher models)
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-005
# Local dev auth: leave blank to use `gcloud auth application-default login` (ADC).
# On Cloud Run, leave blank and attach a service account instead.
# Only set this if you downloaded a service-account key file:
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/sa-key.json

# --- Redis ---
# Local dev: redis://localhost:6379/0
# Prod: redis://:PASSWORD@VM_INTERNAL_IP:6379/0  (from Secret Manager)
REDIS_URL=redis://localhost:6379/0

# --- Generation tuning ---
MAX_OUTPUT_TOKENS=512
TEMPERATURE=0.3
# gemini-2.5-flash "thinking" budget; 0 = off (cheaper + faster, good for short RAG answers)
THINKING_BUDGET=0

# --- Retrieval ---
RETRIEVER_TOP_K=4
KB_DIR=data/knowledge
FAISS_DIR=data/faiss_index

# --- Caching ---
RESPONSE_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_ENABLED=true

# --- Abuse / cost guards ---
RATE_LIMIT_PER_MINUTE=8
RATE_LIMIT_PER_DAY_PER_IP=60
GLOBAL_DAILY_REQUEST_CAP=800
MAX_INPUT_CHARS=1000

# --- App ---
# Comma-separated allowed origins for CORS (the web app origin). * for local dev.
CORS_ALLOW_ORIGINS=*
LOG_LEVEL=INFO
